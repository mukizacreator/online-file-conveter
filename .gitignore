# ============================================
# IGNORED: NODE DEPENDENCIES
# ============================================
# Node.js packages folder - can be restored via package.json
# This folder can be 100+ MB, no need to commit it
node_modules

# ============================================
# IGNORED: TEMPORARY FILES
# ============================================
# Temporary files/folders created during file conversions
# Contains uploaded and converted files (cleaned automatically every 10 minutes)
temp

# Temporary files created by text editors
*.tmp
*.temp

# ============================================
# IGNORED: ENVIRONMENT CONFIGURATION
# ============================================
# Environment variables file - contains secrets, tokens, and credentials (DO NOT COMMIT)
# This file stores: MONGODB_URI, BREVO_API_KEY, EMAIL_FROM, NODE_ENV
.env
.env.local
.env.production
.env.development

# ============================================
# IGNORED: LOGS
# ============================================
# Log files generated by Node.js or npm
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================
# IGNORED: OS FILES
# ============================================
# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux system files
.directory
*.swp
*.swo

# ============================================
# IGNORED: IDE CONFIGURATION
# ============================================
# Visual Studio Code
.vscode/
*.code-workspace

# IntelliJ IDEA / WebStorm / PhpStorm
.idea/
*.iml
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# IGNORED: BUILD OUTPUT
# ============================================
# Build and distribution folders
dist/
build/
out/
*.min.js
*.min.css

# ============================================
# IGNORED: PACKAGE MANAGER LOCK FILES
# ============================================
# Package-lock.json is safe to commit (optional - your choice)
# Uncomment the line below if you want to ignore it
# package-lock.json
# yarn.lock

# ============================================
# IGNORED: TEST COVERAGE
# ============================================
# Test coverage reports (if you add tests later)
coverage/
.nyc_output/

# ============================================
# IGNORED: DOCKER
# ============================================
# Docker temporary files (if any)
.dockerignore

# ============================================
# IGNORED: MISC
# ============================================
# Backup files
*.bak
*.backup

# Debug files
*.log
debug/